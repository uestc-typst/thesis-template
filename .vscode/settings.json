{
    // 预览功能
    "tinymist.previewFeature": "enable",
    // 从不自动导出pdf文件
    "tinymist.exportPdf": "never",
    // "tinymist.exportPdf": "onSave",
    // 输出路径 以pdf结尾!
    "tinymist.outputPath": "${fileWorkspaceFolder}/template/学位论文写作指南及例子",
    "tinymist.rootPath": "${fileWorkspaceFolder}/template",
    // 字体地址, 修改为模板下的fonts目录
    "tinymist.fontPaths": [
        "${fileWorkspaceFolder}/template/uestc-thesis-template/fonts"
    ],
}